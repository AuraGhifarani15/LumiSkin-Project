# Auto detect text files and perform LF normalization
* text=auto

# Force LF for source files
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.env       text eol=lf

# Force CRLF for Windows batch files
*.bat       text eol=crlf
*.cmd       text eol=crlf
# Server Configuration
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
MAX_FILE_SIZE_MB=5
MIN_FILE_SIZE_KB=200
MIN_CONFIDENCE=0.50

# Quota Rate-Limit (Reset per 5 Jam)
DAILY_ANALYSIS_LIMIT=5
DAILY_CHAT_LIMIT=10

# PostgreSQL Database Config
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lumiskin
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# JWT & Session Security
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=12h
SESSION_SECRET=your_session_secret_key_here

# Logging Level
LOG_LEVEL=debug

# Google OAuth Credentials
# Buat credentials di: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email SMTP (Untuk Fitur Reset Password)
# Pilihan 1: Menggunakan Gmail App Password
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM_NAME=LumiSkin

# Pilihan 2: Menggunakan Custom SMTP Server (Mailtrap/SendGrid)
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_SECURE=true
# EMAIL_USER=your_smtp_user
# EMAIL_PASS=your_smtp_password

# Machine Learning Model Server URL (FastAPI)
ML_MODEL_URL=http://localhost:8000

# Groq Cloud AI (Untuk Chat Konsultasi AI)
# Dapatkan API Key di: https://console.groq.com/
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=1024
GROQ_API_KEY=your_groq_api_key_here

# Prisma Database Connection URL
DATABASE_URL="postgresql://postgres:your_database_password_here@localhost:5432/lumiskin_db"
